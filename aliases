# Terminal commands
alias ll="ls -lAFhG"
alias llg="ls -lAFh | grep --color=auto"
alias hg="history | grep --color=auto"
alias bbd="brew bundle dump --force --describe"
alias trail='<<<${(F)path}' # output in a human friendly format the $PATH (works with single quotes this command)
alias repos="cd $REPOS"
alias reload="source $HOME/.zshrc"

# Git

# basic commands
alias gs="git status"
alias ga="git add"
alias gaa="git add ."
alias unga="git restore --staged"
alias ungaa="git restore --staged ."
alias gcm="git commit -m"
alias gca="git commit --amend --no-edit"
alias gh="git log --graph --pretty=format:'%Cred%h%Creset -%C(yellow)%d%Creset %s %Cgreen(%cr) %C(bold blue)<%an>%Creset' --abbrev-commit"

# stashing
alias gst="git stash"
alias gsta="git stash apply"
alias gstc="git stash clear"
alias gstd="git stash drop"
alias gstp="git stash pop"

# branches and diffs
alias gcb="git checkout"
alias gdb="git checkout -d"
alias gnb="git checkout -b"
alias gdf="git diff"

# pushing and pulling
alias push="git push"
alias shove="git push --set-upstream origin"
alias pull="git pull"
alias grab="git fetch && git checkout"

# resetting and cleaning
alias nah="git reset --hard && git clean -df && git pull"
alias mop="git clean -df && git reset --hard && git pull"

# Docker
alias di="docker image"
alias dn="docker network"
alias dv="docker volume"
alias dnuke="docker system prune -a --volumes --force"
alias dkill="docker stop $(docker ps -a -q)"
alias dc="docker compose"
alias dcrun="docker-compose run --rm"
alias dch="docker-compose logs -f"
alias dcdn="docker-compose down -v"
